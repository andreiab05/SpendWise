<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.spendwise.MainController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TableView fx:id="monthlyBudgetTableView">
        <columns>
            <TableColumn fx:id="categoryCol" text="Category" />
            <TableColumn fx:id="spentCol" text="Spent Money" />
            <TableColumn fx:id="budgetCol" text="Monthly Budget" />
        </columns>
    </TableView>

    <HBox>
        <Label text="Select an year." />
        <ComboBox fx:id="yearComboBox" />
    </HBox>

    <HBox>
        <Label text="Select a month." />
        <ComboBox fx:id="monthComboBox" />
    </HBox>

    <HBox>
        <VBox>
            <Label text="Category"/>
            <TextField fx:id="textCategoryName"/>
        </VBox>

        <VBox>
            <Label text="Spent money"/>
            <TextField fx:id="textMoneySpent"/>
        </VBox>

        <VBox>
            <Label text="Budget"/>
            <TextField fx:id="textMonthlyBudget"/>
        </VBox>
    </HBox>

    <HBox spacing="10">
        <Button fx:id="addButton" text="Add new entry" onAction="#onAddClicked"/>
        <Button fx:id="deleteButton" text="Delete entry" onAction="#onDeleteClicked"/>
        <Button fx:id="updateButton" text="Update entry" onAction="#onUpdateEntryClicked"/>
        <Button fx:id="addToAllMonthsButton" text="Add to all months" onAction="#onAddToAllMonths"/>
    </HBox>

</VBox>
